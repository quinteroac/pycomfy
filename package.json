{
  "version": "1.4.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "bump:version": "bun run scripts/bump-version.ts",
    "bump:patch": "BUMP_KIND=patch bun run scripts/bump-version.ts",
    "bump:minor": "BUMP_KIND=minor bun run scripts/bump-version.ts",
    "bump:major": "BUMP_KIND=major bun run scripts/bump-version.ts",
    "ms": "bun run --cwd packages/parallax_ms dev",
    "cli": "bun run --cwd packages/parallax_cli dev",
    "mcp": "bun run --cwd packages/parallax_mcp dev",
    "server": "uv run fastapi dev server/main.py"
  },
  "dependencies": {
    "@quinteroac/agents-coding-toolkit": "^0.4.0"
  }
}
