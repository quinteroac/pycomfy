{
  "name": "@parallax/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "parallax": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "build:linux": "bun build --compile --target=bun-linux-x64 ./src/index.ts --outfile dist/parallax-linux",
    "build:mac": "bun build --compile --target=bun-darwin-x64 ./src/index.ts --outfile dist/parallax-macos",
    "build": "bun run build:linux && bun run build:mac"
  },
  "dependencies": {
    "@clack/prompts": "latest",
    "@parallax/sdk": "workspace:*",
    "commander": "12.x"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "bun-types": "latest"
  }
}
